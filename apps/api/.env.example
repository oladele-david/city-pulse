DATABASE_URL="postgresql://postgres:postgres@localhost:5432/citypulse"
JWT_SECRET="replace-me"
CORS_ORIGIN="http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173,https://city-pulse-lyart.vercel.app,https://*.vercel.app"
FRONTEND_URL="http://localhost:5173"

# Interswitch Web Checkout configuration.
# Use TEST for sandbox and LIVE for production.
INTERSWITCH_MODE="TEST"
INTERSWITCH_BASE_URL="https://newwebpay.qa.interswitchng.com"
INTERSWITCH_REQUERY_BASE_URL="https://qa.interswitchng.com"
INTERSWITCH_MERCHANT_CODE="MX000000"
INTERSWITCH_PAY_ITEM_ID="0000000"
INTERSWITCH_DATA_REF="optional-data-ref"
INTERSWITCH_CLIENT_ID="optional-client-id"
INTERSWITCH_SECRET_KEY="optional-secret-key"
INTERSWITCH_WEBHOOK_SECRET="replace-with-your-webhook-secret"
INTERSWITCH_REDIRECT_URL="http://localhost:5173/payment/callback"
INTERSWITCH_WEBHOOK_URL="https://your-public-api-domain.example.com/api/v1/payments/webhook"

# Local webhook testing requires a public tunnel such as ngrok or Cloudflare Tunnel.
# Interswitch cannot send webhook events directly to localhost URLs.
PERSISTENCE_DRIVER="database"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
